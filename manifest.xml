<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<plugin name="Mechanics">
	<info>
		<version>1.0</version>
		<executable>Mechanics.exe</executable>
		<developer name="Martin Lacroix" email="martin.lacroix@student.unamur.be"/>
		<readme>README.txt</readme>
	</info>

	<requiredFiles>
		<file type="OUTPUT_TOTAL" >
			<name>coating.xyz</name>
		</file>
	</requiredFiles>
	
	<userInput>
		<group name="Simulation Type">
			<param type="LIST" ref="Model">
				<name>Material Model</name>
				<element>Linear SET/SST Model</element>
				<element>Saint Venant-Kirchhoff</element>
				<default>Linear SET/SST Model</default>
			</param>
			<param type="LIST" ref="Layer">
				<name>Studied layers</name>
				<element>Whole structure</element>
				<element>Manual selection</element>
				<default>Whole structure</default>
			</param>
		</group>

		<group name="Input File" displayIf="Layer:Manual selection">
			<param type="FILE" toPath="true">
				<name>Coating file path</name>
			</param>
		</group>

		<group name="General Parameters" displayIf="Model:Linear SET/SST Model">
			<param type="DOUBLE">
				<name>Lattice constant</name>
				<default>1</default>
				<unit>nm</unit>
			</param>
			<param type="DOUBLE">
				<name>Smoothing depth</name>
				<default>0</default>
				<unit>Lc</unit>
			</param>
		</group>

		<group name="General Parameters" displayIf="Model:Saint Venant-Kirchhoff">
			<param type="DOUBLE">
				<name>Lattice constant</name>
				<default>1</default>
				<unit>nm</unit>
			</param>
			<param type="DOUBLE">
				<name>Smoothing depth</name>
				<default>0</default>
				<unit>nm</unit>
			</param>
			<param type="INT">
				<name>Load steps</name>
				<default>1</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Tolerance Newton</name>
				<default>1e-6</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Finite Elements">
			<param type="INT">
				<name>Element order</name>
				<default>1</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Length along X</name>
				<default>1</default>
				<unit>Lc</unit>
			</param>
			<param type="DOUBLE">
				<name>Length along Y</name>
				<default>1</default>
				<unit>Lc</unit>
			</param>
			<param type="DOUBLE">
				<name>Length along Z</name>
				<default>1</default>
				<unit>Lc</unit>
			</param>
		</group>

		<group name="Hole Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>0</default>
				<unit>GPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Max filling</name>
				<default>0.5</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Substrate Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>200</default>
				<unit>GPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>
		
		<group name="Boundary Conditions" >
			<param type="LIST">
				<name>Load type</name>
				<element>Z-axis</element>
				<element>Y-axis</element>
				<element>X-axis</element>
				<default>Z-axis</default>
			</param>
			<param type="LIST">
				<name>Free surface</name>
				<element>Top</element>
				<element>Bottom</element>
				<element>Both</element>
				<element>None</element>
				<default>Top</default>
			</param>
			<param type="LIST">
				<name>Transversal strain</name>
				<element>Periodic strain</element>
				<element>Periodic (no strain)</element>
				<element>Uniform strain</element>
				<element>Uniform (no strain)</element>
				<default>Locked</default>
			</param>
			<param type="DOUBLE">
				<name>Applied stress</name>
				<default>1</default>
				<unit>GPa</unit>
			</param>
		</group>

		<group name="Layer Parameters" type="LAYER_TABLE" displayIf="Model:Linear SET/SST Model">
			<param type="DOUBLE" >
				<name>Young modulus (GPa)</name>
				<default>130</default>
			</param>
			<param type="DOUBLE" >
				<name>Poisson ratio (-)</name>
				<default>0.3</default>
			</param>
			<param type="DOUBLE" >
				<name>Surface λ (N/m)</name>
				<default>0</default>
			</param>
			<param type="DOUBLE" >
				<name>Surface μ (N/m)</name>
				<default>0</default>
			</param>
			<param type="DOUBLE" >
				<name>Surface tension (N/m)</name>
				<default>0</default>
			</param>
		</group>

		<group name="Layer Parameters" type="LAYER_TABLE" displayIf="Model:Saint Venant-Kirchhoff">
			<param type="DOUBLE" >
				<name>Young modulus (GPa)</name>
				<default>130</default>
			</param>
			<param type="DOUBLE" >
				<name>Poisson ratio (-)</name>
				<default>0.3</default>
			</param>
		</group>
	</userInput>
	
	<userOutput>
		<displayJmol>true</displayJmol>
		<displayGraph>true</displayGraph>
		<displayLog>true</displayLog>
	</userOutput>
	
</plugin>