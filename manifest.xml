<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<plugin name="Mechanics">
	<info>
		<version>1.0</version>
		<executable>Mechanics.exe</executable>
		<developer name="You" email="Your email"/>
		<readme>readme.txt</readme>
	</info>

	<requiredFiles>
		<file type="OUTPUT">
			<name>deposited_layer.xyz</name>
		</file>
	</requiredFiles>
	
	<userInput>
		<group name="General Parameters">
			<param type="INT">
				<name>Quadrature order</name>
				<default>1</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Filling threshold</name>
				<default>0.5</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Bulk Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>1</default>
				<unit>MPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Hole Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>1</default>
				<unit>MPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>
		
		<group>
			<param type="LIST" ref="X">
				<name>BC along X axis</name>
				<element>clamped bottom</element>
				<element>periodic free</element>
				<element>imposed strain</element>
			</param>
		</group>
		<group displayIf="X:imposed strain">
			<param type="DOUBLE">
				<name>Total strain</name>
				<default>0</default>
				<unit>?</unit>
			</param>
		</group>

		<group>
			<param type="LIST" ref="Y">
				<name>BC along Y axis</name>
				<element>clamped bottom</element>
				<element>periodic free</element>
				<element>imposed strain</element>
			</param>
		</group>
		<group displayIf="Y:imposed strain">
			<param type="DOUBLE">
				<name>Total strain</name>
				<default>0</default>
				<unit>?</unit>
			</param>
		</group>

		<group>
			<param type="LIST" ref="Z">
				<name>BC along Z axis</name>
				<element>clamped bottom</element>
				<element>periodic free</element>
				<element>imposed strain</element>
			</param>
		</group>
		<group displayIf="Z:imposed strain">
			<param type="DOUBLE">
				<name>Total strain</name>
				<default>0</default>
				<unit>?</unit>
			</param>
		</group>
	</userInput>
	
	<userOutput>
		<displayJmol>true</displayJmol>
		<displayGraph>true</displayGraph>
		<displayLog>true</displayLog>
	</userOutput>
	
</plugin>