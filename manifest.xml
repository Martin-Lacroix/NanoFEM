<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<plugin name="Mechanics">
	<info>
		<version>1.0</version>
		<executable>Mechanics.exe</executable>
		<developer name="You" email="Your email"/>
		<readme>readme.txt</readme>
	</info>

	<requiredFiles>
		<file type="OUTPUT">
			<name>coating.xyz</name>
		</file>
	</requiredFiles>
	
	<userInput>
		<group name="General Parameters">
			<param type="INT">
				<name>Element order</name>
				<default>1</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Lattice constant</name>
				<default>1</default>
				<unit>nm</unit>
			</param>
			<param type="DOUBLE">
				<name>Smoothing depth</name>
				<default>0</default>
				<unit>nm</unit>
			</param>
		</group>

		<group name="Hole Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>0</default>
				<unit>GPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Substrate Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>1</default>
				<unit>GPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>
		
		<group>
			<param type="LIST" ref="Type">
				<name>Load Type</name>
				<element>Axial stress</element>
				<element>Shear stress</element>
				<element>Hydrostatic</element>
				<default>Axial stress</default>
			</param>
		</group>
		<group name="Load Parameters" displayIf="Type:Axial stress">
			<param type="LIST">
				<name>Dimension</name>
				<element>eXX</element>
				<element>eYY</element>
				<element>eZZ</element>
				<default>eXX</default>
			</param>
			<param type="DOUBLE">
				<name>Axial stress</name>
				<default>1</default>
				<unit>GPa</unit>
			</param>
		</group>
		<group name="Load Parameters" displayIf="Type:Shear stress">
			<param type="LIST">
				<name>Dimension</name>
				<element>eXY</element>
				<element>eYX</element>
				<element>eZY</element>
				<element>eZX</element>
				<default>eXY</default>
			</param>
			<param type="DOUBLE">
				<name>Shear stress</name>
				<default>1</default>
				<unit>GPa</unit>
			</param>
		</group>
		<group name="Load Parameters" displayIf="Type:Hydrostatic">
			<param type="LIST">
				<name>Dimension</name>
				<element>All</element>
				<element>eZZ</element>
				<default>All</default>
			</param>
			<param type="DOUBLE">
				<name>Normal stress</name>
				<default>1</default>
				<unit>GPa</unit>
			</param>
		</group>

		<group name="Layer Parameters" type="LAYER_TABLE">
			<param type="DOUBLE" >
				<name>Young modulus (GPa)</name>
				<default>1</default>
			</param>
			<param type="DOUBLE" >
				<name>Poisson ratio</name>
				<default>0.3</default>
			</param>
			<param type="DOUBLE" >
				<name>Surface modulus (N/m)</name>
				<default>0</default>
			</param>
			<param type="DOUBLE" >
				<name>Surface ratio</name>
				<default>0</default>
			</param>
			<param type="DOUBLE" >
				<name>Surface tension (N/m)</name>
				<default>0</default>
			</param>
		</group>
	</userInput>
	
	<userOutput>
		<displayJmol>true</displayJmol>
		<displayGraph>true</displayGraph>
		<displayLog>true</displayLog>
	</userOutput>
	
</plugin>