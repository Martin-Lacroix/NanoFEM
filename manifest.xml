<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<plugin name="Mechanics">
	<info>
		<version>1.0</version>
		<executable>Mechanics.exe</executable>
		<developer name="You" email="Your email"/>
		<readme>readme.txt</readme>
	</info>

	<requiredFiles>
		<file type="OUTPUT">
			<name>deposited_layer.xyz</name>
		</file>
	</requiredFiles>
	
	<userInput>
		<group name="General parameters">
			<param type="INT">
				<name>Quadrature Order</name>
				<default>1</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Young Modulus</name>
				<default>1</default>
				<unit>MPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson Ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Dirichlet boundary conditions">
			<param type="DOUBLE">
				<name>Ux Face [-x]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Ux Face [+x]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uy Face [-y]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uy Face [+y]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uz Face [-z]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uz Face [+z]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
		</group>
	</userInput>
	
	<userOutput>
		<displayJmol>true</displayJmol>
		<displayGraph>true</displayGraph>
		<displayLog>true</displayLog>
	</userOutput>
	
</plugin>