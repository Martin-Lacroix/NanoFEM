<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<plugin name="Mechanics">
	<info>
		<version>1.0</version>
		<executable>Mechanics.exe</executable>
		<developer name="You" email="Your email"/>
		<readme>readme.txt</readme>
	</info>

	<requiredFiles>
		<file type="OUTPUT">
			<name>deposited_layer.xyz</name>
		</file>
	</requiredFiles>
	
	<userInput>
		<group name="General Parameters">
			<param type="INT">
				<name>Quadrature order</name>
				<default>1</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Filling threshold</name>
				<default>0.5</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Bulk Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>1</default>
				<unit>MPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Hole Parameters">
			<param type="DOUBLE">
				<name>Young modulus</name>
				<default>1</default>
				<unit>MPa</unit>
			</param>
			<param type="DOUBLE">
				<name>Poisson ratio</name>
				<default>0.3</default>
				<unit>-</unit>
			</param>
		</group>

		<group name="Dirichlet Boundary Conditions">
			<param type="DOUBLE">
				<name>Ux face [-x]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Ux face [+x]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uy face [-y]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uy face [+y]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uz face [-z]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
			<param type="DOUBLE">
				<name>Uz face [+z]</name>
				<default>NaN</default>
				<unit>-</unit>
			</param>
		</group>
	</userInput>
	
	<userOutput>
		<displayJmol>true</displayJmol>
		<displayGraph>true</displayGraph>
		<displayLog>true</displayLog>
	</userOutput>
	
</plugin>